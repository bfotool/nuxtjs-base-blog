# ===========================================
# Nuxt Blog - Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# Nuxt uses NUXT_PUBLIC_ prefix for client-side vars.

# --- App ---
NUXT_PUBLIC_APP_NAME="Bfotool Blog"
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Dev server port (used by `nuxt dev`)
PORT=3000

# --- API ---
# Set to "true" to use fake/mock API, "false" for real API
NUXT_PUBLIC_USE_MOCK_API=true

# Base URL for real API (ignored when using mock)
NUXT_PUBLIC_API_BASE_URL=https://api.example.com

# --- Analytics (optional) ---
# NUXT_PUBLIC_GA_ID=G-XXXXXXXXXX
